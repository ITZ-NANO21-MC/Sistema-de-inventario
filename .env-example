# =============================================================================
# Archivo de configuración de entorno (plantilla)
# =============================================================================
# Copia este archivo como .env y completa los valores:
#   cp .env-example .env
#
# ⚠️  NUNCA subas el archivo .env al repositorio. Contiene credenciales.
# =============================================================================

# -----------------------------------------------------------------------------
# Clave secreta (OBLIGATORIA - mínimo 32 caracteres)
# Genera una segura con: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga-y-segura-de-al-menos-32-caracteres

# -----------------------------------------------------------------------------
# Base de datos
# Por defecto usa SQLite. Para PostgreSQL: postgresql://user:pass@host:5432/db
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///inventario.db

# -----------------------------------------------------------------------------
# Configuración de Correo (Flask-Mail)
# Ejemplo con Gmail: usa una contraseña de aplicación, no tu contraseña normal.
# https://support.google.com/accounts/answer/185833
# -----------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-contraseña-de-aplicacion
MAIL_DEFAULT_SENDER=tu-email@gmail.com

# -----------------------------------------------------------------------------
# Tasa de cambio USD a Bs
# Se usa para convertir precios y recalcular al actualizar la configuración.
# -----------------------------------------------------------------------------
TASA_CAMBIO_USD_BS=0

# -----------------------------------------------------------------------------
# Jobs programados (Flask-APScheduler)
# Cada job tiene: hora (0-23), minuto (0-59), activo (true/false)
# Zona horaria: America/Caracas (UTC-4)
# -----------------------------------------------------------------------------

# Alerta de stock bajo - envía email si hay productos con stock <= mínimo
JOB_ALERTA_STOCK_HORA=8
JOB_ALERTA_STOCK_MINUTO=0
JOB_ALERTA_STOCK_ACTIVO=true

# Informe general de la mañana - informe completo del inventario
JOB_INFORME_MANANA_HORA=7
JOB_INFORME_MANANA_MINUTO=0
JOB_INFORME_MANANA_ACTIVO=true

# Informe general de la tarde - informe completo del inventario
JOB_INFORME_TARDE_HORA=19
JOB_INFORME_TARDE_MINUTO=0
JOB_INFORME_TARDE_ACTIVO=true

# Respaldo diario - comprime la DB y la envía por correo
JOB_BACKUP_HORA=21
JOB_BACKUP_MINUTO=0
JOB_BACKUP_ACTIVO=true

# -----------------------------------------------------------------------------
# Modo de ejecución
# FLASK_DEBUG: True para desarrollo (recarga automática, debug pages)
# FORCE_HTTPS: True para producción (fuerza HTTPS con HSTS)
# -----------------------------------------------------------------------------
FLASK_DEBUG=False
FORCE_HTTPS=False
